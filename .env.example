# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Environment
NODE_ENV=production
LOG_LEVEL=info

# Storefront Configuration
STOREFRONT_TYPE=shopify
# STOREFRONT_TYPE=woocommerce
# STOREFRONT_TYPE=custom

# Shopify Integration (if using Shopify)
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_PASSWORD=your_api_password
SHOPIFY_API_VERSION=2024-01

# WooCommerce Integration (if using WooCommerce)
WOOCOMMERCE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=your_consumer_key
WOOCOMMERCE_CONSUMER_SECRET=your_consumer_secret

# Supplier APIs
CJ_DROPSHIPPING_API_KEY=your_cj_api_key
USA_DROP_API_KEY=your_usa_drop_api_key

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=alerts@example.com

# Trending Data Sources
TIKTOK_API_KEY=optional_tiktok_api_key
INSTAGRAM_ACCESS_TOKEN=optional_instagram_token
GOOGLE_TRENDS_API_KEY=optional_google_trends_key

# Application Settings
MIN_MARGIN_RATIO=2.0
MAX_PRODUCT_WEIGHT_LBS=2.0
BATCH_SIZE=50
RESEARCH_INTERVAL_HOURS=4
SYNC_INTERVAL_HOURS=2
